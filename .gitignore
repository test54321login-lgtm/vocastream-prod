# =============================================================================
# VOCASTREAM .gitignore - Production Ready
# =============================================================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock

# Environment variables
.env
.env.local
.env.*.local
.env.production
.env.backup

# Backend
backend/node_modules/
backend/*.log

# Frontend  
frontend/node_modules/
frontend/*.log

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
.classpath
*.sublime-*

# Logs
logs/
*.log
log/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
.nyc_output/

# Build outputs
dist/
build/
out/

# Temporary files
tmp/
temp/
*.tmp

# Kaggle specific (if downloaded models)
models/
checkpoints/
*.h5
*.pth
*.pkl
*.bin

# Audio outputs (can be regenerated)
output/
outputs/
*.wav
*.mp3
*.flac

# Database
*.db
*.sqlite
*.sqlite3

# Secrets and credentials (keep template only)
*.pem
*.key
*.crt
*.p12

# Misc
*.bak
*.orig
 *__pycache__/
 *.pyc