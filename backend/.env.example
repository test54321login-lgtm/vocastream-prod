# =============================================================================
# VOCASTREAM Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# =============================================================================

# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Connection (replace with your MongoDB Atlas URI)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/vocastream?w=majority

# JWT Secret (generate a strong random string - minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-use-openssl-rand-hex-32

# Frontend URL (for CORS - change in production for Vercel)
FRONTEND_URL=https://your-project.vercel.app

# Serve frontend from backend (set to 'false' for Vercel + Railway)
SERVE_FRONTEND=false

# =============================================================================
# AI Engine Configuration (Kaggle)
# =============================================================================
# Your Kaggle Notebooks API endpoint (must be kept running)
KAGGLE_URL=https://your-ngrok-url.ngrok-free.app/generate-internal

# Internal secret (must match your Kaggle notebook's INTERNAL_SECRET)
INTERNAL_SECRET=SELLSHOUT_INTERNAL_SECRET_99